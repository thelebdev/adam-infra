#!/usr/bin/env bash
# sandbox-shell — launch an interactive login shell inside a bubblewrap jail.
#
# This is what `session` runs when the user picks the "shell" command for a
# browser terminal session. The jail's goals:
#
#   * Workspace is the only writable place — system paths (/usr, /etc, /bin,
#     /sbin, /lib*) are mounted read-only; everything else (/var, /opt, /mnt,
#     /srv, /media, …) is simply not present, so the operator cannot even
#     `cd` outside what's mounted. Home dirs are tmpfs (so secrets at ~/.ssh,
#     ~/.gnupg, etc. are invisible).
#   * Two TOTP-gated escapes from inside the sandbox:
#       * `break`  — fresh login bash, unconfined
#       * `claude` — Claude Code, unconfined
#     Both shims (bound into /home/sandbox/bin/) ask the tmux server
#     (running OUTSIDE bwrap as the admin user) to `respawn-pane` the
#     calling pane with the corresponding host-side helper. Same window,
#     same scrollback, no new tab. Sudo is NOT used — sudo cannot run
#     inside an unprivileged user namespace; see platform/ttyd/break.py
#     for the long-form rationale.
#
# Args:
#   $1  outer absolute path to the project dir for the session — used to
#       compute the equivalent path inside the sandbox so `cd` lands in the
#       same project the dashboard chose at session creation.
#
# Env (set by the parent `session` helper, propagated into the jail):
#   SESSION_WORKSPACE_ROOT   the host workspace root (default ~/workspace)
#   SESSION_SOCKET_DIR       the host tmux socket dir (default ~/.terminal-sessions)
#   TTYD_USER                Authelia identity — used by `break` to look up
#                            the right TOTP secret
set -euo pipefail

WORKSPACE_ROOT="${SESSION_WORKSPACE_ROOT:-${HOME}/workspace}"
SOCKET_DIR="${SESSION_SOCKET_DIR:-${HOME}/.terminal-sessions}"
TTYD_USER="${TTYD_USER:-$(id -un)}"
SOCKET="${SOCKET_DIR}/${TTYD_USER}.sock"

target="${1:-${WORKSPACE_ROOT}}"
# Compute the equivalent of `target` *inside* the sandbox. The workspace is
# bind-mounted at /home/sandbox/workspace (inside the /home tmpfs so bwrap
# can create the mount point under a read-only root — bwrap 0.9.0 on
# Ubuntu 24.04 refuses to mkdir mount points under a --ro-bind / / root).
# Anything outside the host workspace just lands at the sandbox workspace
# root.
SANDBOX_WS="/home/sandbox/workspace"
inside_chdir="${SANDBOX_WS}"
case "${target}" in
  "${WORKSPACE_ROOT}") inside_chdir="${SANDBOX_WS}" ;;
  "${WORKSPACE_ROOT}/"*)
    rel="${target#${WORKSPACE_ROOT}/}"
    inside_chdir="${SANDBOX_WS}/${rel}"
    ;;
esac

# Sanity: tmux socket must exist; otherwise `sudo break` can't talk back.
# (Not fatal — the shell still works, just no break-out.)
sock_args=()
if [ -S "${SOCKET}" ]; then
  sock_args=(--ro-bind "${SOCKET}" /run/session.sock)
fi

# TMUX env var format: <socket>,<pid>,<session_id>. tmux clients only need
# the socket to find the server; the other fields are advisory. We override
# the host path with the sandboxed path so `tmux` commands inside the jail
# (including `break`'s `tmux respawn-pane`) work.
host_tmux="${TMUX:-}"
if [ -n "${host_tmux}" ]; then
  tmux_rest="${host_tmux#*,}"
  sandbox_tmux="/run/session.sock,${tmux_rest}"
else
  sandbox_tmux=""
fi

# The user's pane id, propagated so `break` knows which pane to respawn.
pane="${TMUX_PANE:-}"

exec /usr/bin/bwrap \
  --ro-bind /usr /usr \
  --ro-bind /etc /etc \
  --ro-bind /bin /bin \
  --ro-bind /sbin /sbin \
  --ro-bind-try /lib /lib \
  --ro-bind-try /lib32 /lib32 \
  --ro-bind-try /lib64 /lib64 \
  --ro-bind-try /libx32 /libx32 \
  --tmpfs /tmp \
  --tmpfs /var \
  --tmpfs /home \
  --tmpfs /root \
  --bind "${WORKSPACE_ROOT}" "${SANDBOX_WS}" \
  --ro-bind /opt/infra/platform/ttyd/claude-shim /home/sandbox/bin/claude \
  --ro-bind /opt/infra/platform/ttyd/break-shim /home/sandbox/bin/break \
  "${sock_args[@]}" \
  --setenv HOME /home/sandbox \
  --setenv USER "${TTYD_USER}" \
  --setenv LOGNAME "${TTYD_USER}" \
  --setenv PATH "/home/sandbox/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
  --setenv TTYD_USER "${TTYD_USER}" \
  --setenv TMUX "${sandbox_tmux}" \
  --setenv TMUX_PANE "${pane}" \
  --setenv SANDBOX "1" \
  --setenv PS1 '\[\033[1;33m\][sandbox]\[\033[0m\] \w \$ ' \
  --chdir "${inside_chdir}" \
  --proc /proc \
  --dev /dev \
  --die-with-parent \
  --unshare-ipc \
  --unshare-uts \
  --unshare-pid \
  --new-session \
  -- /bin/bash -l
