#!/usr/bin/env bash
# claude-shim — bind-mounted by sandbox-shell at /home/sandbox/bin/claude
# inside the bubblewrap sandbox. Outside the sandbox /usr/local/bin/claude
# does not exist; the real binary lives at ~/.local/bin/claude.
#
# Sudo cannot work inside an unprivileged user namespace — Ubuntu 24.04
# bwrap sets PR_SET_NO_NEW_PRIVS=1 (blocks setuid) and maps host UID 0 to
# `nobody/65534` inside the sandbox (sudo refuses on the "wrong owner"
# check). So instead of trying to elevate inside, we ESCAPE the sandbox
# first by asking the tmux server (which runs OUTSIDE bwrap as the admin
# user) to respawn this pane with the TOTP-gated helper. The helper then
# validates Authelia TOTP and execs Claude Code unconfined in the same
# pane, no new tab.
exec tmux respawn-pane -k -- /usr/local/sbin/claude-break-out
